data class Lex(val src: String, var pos: Int)

fn skipWs(mutref lex: Lex) {
  if lex.pos >= lex.src.len() { return }
  val ch = lex.src.charAt(lex.pos)
  if ch == " " or ch == "\n" {
    lex.pos = lex.pos + 1
    skipWs(mutref lex)
  }
}

fn tokLoop(mutref lex: Lex, mutref tokens: List<String>) {
  skipWs(mutref lex)
  if lex.pos >= lex.src.len() { return }
  val ch = lex.src.charAt(lex.pos)
  lex.pos = lex.pos + 1
  tokens.push(ch)
  tokLoop(mutref lex, mutref tokens)
}

@entrypoint
fn main() {
  var lex = Lex("a b c d e", 0)
  var tokens: List<String> = []
  tokLoop(mutref lex, mutref tokens)
  println(tokens.len())
}
