data class Lexer(
  val src: String,
  var pos: Int,
  var line: Int,
  var col: Int
)

fn Lexer.cur(ref self) -> String {
  if self.pos >= self.src.len() { return "" }
  self.src.charAt(self.pos)
}

fn isAlpha(ch: String) -> Bool {
  if ch.len() == 0 { return false }
  val c = ch.charCodeAt(0)
  (c >= 65 and c <= 90) or (c >= 97 and c <= 122) or c == 95
}

fn isDigit(ch: String) -> Bool {
  if ch.len() == 0 { return false }
  val c = ch.charCodeAt(0)
  c >= 48 and c <= 57
}

@entrypoint
fn main() {
  val lex = Lexer("hello", 0, 1, 1)
  println(lex.cur())
  println(isAlpha("h"))
  println(isDigit("5"))
}
