// EXPECTED OUTPUT:
// 10 / 3 = 3
// 10.0 / 4.0 = 2.5
// 7 % 3 = 1
// -7 / 2 = -4

// Integer division truncates toward negative infinity (Python semantics).
// Float division produces a float.

@entrypoint
fn main() {
  println(f"10 / 3 = {10 / 3}")
  println(f"10.0 / 4.0 = {10.0 / 4.0}")
  println(f"7 % 3 = {7 % 3}")
  println(f"-7 / 2 = {-7 / 2}")
}
