// EXPECTED WARNING:
// warning: write guard held across await point
//        another task waiting on `db.write()` will be blocked
//        for the entire await duration
//   --> write_guard_across_await.fuse:13:16

@rank(1) val db = Shared::new(0)

async fn fetchData() -> Int { 42 }

async fn broken() {
  val mutref guard = db.write()       // write guard acquired
  val result = await fetchData()      // warning: guard held across await
  guard = result
}
